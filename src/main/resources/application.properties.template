spring.application.name=gvr-tech-notes
spring.main.banner-mode=off

# DATABASE
spring.datasource.url=jdbc:mysql://localhost:3306/gvr_tech_notes
spring.datasource.username=root
spring.datasource.password=YOUR_DB_PASSWORD
server.port=8091

# JPA
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=false

# THYMELEAF
spring.thymeleaf.cache=false

# SESSION
server.servlet.session.timeout=30m

# ACTUATOR
management.endpoints.web.exposure.include=health,info
management.endpoint.health.show-details=always

# LOGGING
logging.level.root=INFO
logging.level.com.gvr=DEBUG
logging.level.org.springframework=WARN
logging.level.org.hibernate.SQL=WARN
logging.file.name=logs/gvr-notes.log
logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n
logging.pattern.file=%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n

# ── MAIL (password reset) ────────────────────────────────────────────────────
# Gmail: enable 2FA, create an App Password at myaccount.google.com/apppasswords
spring.mail.host=${SPRING_MAIL_HOST:smtp.gmail.com}
spring.mail.port=${SPRING_MAIL_PORT:587}
spring.mail.username=${SPRING_MAIL_USERNAME:your@gmail.com}
spring.mail.password=${SPRING_MAIL_PASSWORD:your-app-password}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Admin bootstrap credentials
admin.username=venky
admin.password=${ADMIN_PASSWORD:your-admin-password}

# Groq AI — get free key at console.groq.com
groq.api.key=${GROQ_API_KEY:your-groq-api-key}
groq.api.url=https://api.groq.com/openai/v1/chat/completions
# Active Groq models (free tier):
#   llama-3.3-70b-versatile | llama-3.1-70b-versatile | moonshotai/kimi-k2-instruct
# Check current list: https://console.groq.com/docs/models
groq.model=llama-3.3-70b-versatile
